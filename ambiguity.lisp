
;;;; ====================================================================
;;;; ambiguity.lisp — Morphological ambiguity distribution data
;;;; ====================================================================
;;;;
;;;; Contains ambiguity frequency distributions for Abkhaz, Georgian,
;;;; and Norwegian, formatted as Python dicts for plotting.  Each entry
;;;; maps ambiguity level (number of readings per token) to the frequency
;;;; per 100,000 tokens.  Two distributions per language: full readings
;;;; (up to 146 levels) and lemma-level ambiguity (up to 24 levels).
;;;; ====================================================================

(in-package :kp)

;; Formats an ambiguity frequency list as a Python dict literal.
(defun format-py (list count)
  (write-string "{")
  (let ((len (length list)))
    (loop for amb from 1 to count
          for fr = (if (< amb len) (nth amb list) 0)  
          do (format t "~a:~a" amb fr)
          when (< amb count) do (write-char #\,))
    (write-line "}")))

